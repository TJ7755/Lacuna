.venv/
__pycache__/
.pytest_cache/
# data/* rather than data/, so the re-inclusion below works: git will not descend
# into an excluded directory, and a file cannot be re-included once a parent is.
data/*
# The held-out set is hand-written and manually labelled, so unlike the generated
# batches under data/raw/ it cannot be regenerated. It is the only human judgement
# in the corpus (see next_plan.md Appendix A.1 Step 4), so it is tracked.
!data/held_out/

models/
reports/
