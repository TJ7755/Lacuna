# Lacuna — environment variables
#
# v1 note: No environment variables are required to run Lacuna v1.
# All configuration (LLM provider, API keys, theme) is stored in the
# local SQLite database and managed via the Settings page in the app.
#
# The variables below are placeholders for v2 sync backend features.
# They are not read by the frontend build.

# ── v2: Auth0 (sync backend) ──────────────────────────────────────────
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=

# ── v2: Azure (sync backend) ──────────────────────────────────────────
AZURE_POSTGRESQL_URL=
AZURE_BLOB_STORAGE_URL=
